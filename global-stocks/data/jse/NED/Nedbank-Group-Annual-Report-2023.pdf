<div class="contentblockv2">
    


    
    




    

    <div id="contentblockv2_203658">
    
        
        
        
            <section><div class="contentblock-container centredcontentblock">
    <div class="ng-container imageshadow  primary-bg inline">
        <section class="col-lg-6 col-md-6 col-sm-12">
            <picture>
                <source media="(min-width: 1025px)" srcset="/content/dam/group/images/home/colleagues-in-meeting.jpg"/>
                <source media="(min-width: 768px)" srcset="/content/dam/group/images/home/colleagues-in-meeting.jpg/_jcr_content/renditions/cq5dam.resized.mobi548.png"/>
                <source media="(max-width: 767px)" srcset="/content/dam/group/images/home/colleagues-in-meeting.jpg/_jcr_content/renditions/cq5dam.resized.mobi320.png"/>
